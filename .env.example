# .env.example
# Copy this file to .env and fill in real values locally — never commit real secrets here.
VITE_APP_URL=https://your-app-url.example.com
VITE_WEATHER_API_KEY=your-weather-api-key
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
# Required for the AI plant-scan (/api/vision). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key
